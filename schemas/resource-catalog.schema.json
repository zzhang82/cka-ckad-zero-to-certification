{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CKA/CKAD resource catalog",
  "type": "object",
  "required": ["schema_version", "resources"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "owner", "authority", "access", "license", "adoption", "weeks", "last_verified", "notes"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
          "title": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "owner": {"type": "string", "minLength": 1},
          "authority": {"enum": ["official", "purchased", "community"]},
          "access": {"type": "string", "minLength": 1},
          "license": {"type": "string", "minLength": 1},
          "adoption": {"enum": ["primary", "map-only", "supplemental", "link-only", "reject"]},
          "weeks": {"type": "array", "items": {"type": "string", "pattern": "^week-(0[0-9]|1[0-2])$"}, "minItems": 1},
          "last_verified": {"type": "string", "format": "date"},
          "notes": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
